# ── HireMind Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values for local dev.
# On Railway, set these in the Railway dashboard → Variables tab.
# NEVER commit .env to git.

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-LONG-RANDOM-STRING-IN-PRODUCTION
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app,localhost,127.0.0.1

# ── Database (Railway auto-injects this when you add PostgreSQL) ──────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Redis (Railway auto-injects this when you add Redis) ─────────────────────
# REDIS_URL=redis://default:pass@host:6379

# ── Groq AI ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── CORS (add your Vercel frontend URL here in production) ────────────────────
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
